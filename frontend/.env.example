# Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Building API
BUILDING_API_KEY=YOUR_BUILDING_API_KEY

# Google Service Account for Google Sheets (Server-side)
GOOGLE_SERVICE_ACCOUNT_EMAIL=YOUR_SERVICE_ACCOUNT_EMAIL
GOOGLE_PRIVATE_KEY="YOUR_PRIVATE_KEY_HERE"

# Firebase Client configuration
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY

# Firebase AuthDomain 설정 (보안 향상을 위한 커스텀 도메인 권장)
# 기본값: [PROJECT_ID].firebaseapp.com
# 커스텀 도메인 적용 시: auth.yourdomain.com 또는 yourdomain.com (자세한 설정은 docs/firebase-custom-auth-domain.md 참고)
# 이를 통해 로그인 팝업 및 리디렉션 시 구글 로그인 창에서 피싱 방지 및 보안 신뢰성을 강화할 수 있습니다.
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com

NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# Redis Configuration (Upstash)
UPSTASH_REDIS_REST_URL=YOUR_REDIS_REST_URL
UPSTASH_REDIS_REST_TOKEN=YOUR_REDIS_REST_TOKEN

# Firebase App Check (reCAPTCHA Enterprise)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
# 로컬 개발 환경 검증용 App Check 디버그 토큰 (필요시 기입)
NEXT_PUBLIC_APPCHECK_DEBUG_TOKEN=

# Google Analytics
NEXT_PUBLIC_GA_ID=YOUR_GA_ID
GA_PROPERTY_ID=YOUR_GA_PROPERTY_ID
ECOS_API_KEY=YOUR_ECOS_API_KEY
NEXT_PUBLIC_KAKAO_JS_KEY=YOUR_KAKAO_JS_KEY

# Firebase Service Account JSON (Server-side API)
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key_id":"","private_key":"YOUR_PRIVATE_KEY","client_email":"","client_id":"","auth_uri":"","token_uri":"","auth_provider_x509_cert_url":"","client_x509_cert_url":""}'

# Web Push VAPID Keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY

# Google AdSense Client ID & Ad Unit Slots
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-YOUR_CLIENT_ID
NEXT_PUBLIC_ADSENSE_SLOT_APT_MODAL=YOUR_SLOT_ID
NEXT_PUBLIC_ADSENSE_SLOT_GAP_EXPLORER=YOUR_SLOT_ID
NEXT_PUBLIC_ADSENSE_SLOT_DASHBOARD_BOTTOM=YOUR_SLOT_ID
NEXT_PUBLIC_ADSENSE_SLOT_LOUNGE_DETAIL=YOUR_SLOT_ID
NEXT_PUBLIC_ADSENSE_SLOT_ANCHOR=YOUR_SLOT_ID
