rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profiles: Authenticated user can read/write their own profile images
    match /profiles/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Field Reports: Authenticated user can read/write
    match /reports/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Posts: Authenticated user can read/write
    match /posts/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Reviews: Authenticated user can read/write
    match /reviews/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Default rule: Restrict reads and writes to authenticated admins for undefined paths
    match /{allPaths=**} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
